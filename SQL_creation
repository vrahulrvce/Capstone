-------------------- FACT TABLE ---------------------- done   
CREATE TABLE IF NOT EXISTS fact_main (
    fact_id BIGSERIAL PRIMARY KEY,
    time_id INT NOT NULL,
    cmp_id INT NOT NULL,
    drug_id INT NOT NULL,
    demo_id INT NOT NULL,
    type_d INT NOT NULL,
    icd_code TEXT,
    description TEXT,
    total_count BIGINT,
    CONSTRAINT fk_time FOREIGN KEY (time_id) REFERENCES dim_time (time_id),
    CONSTRAINT fk_cmp FOREIGN KEY (cmp_id) REFERENCES dim_cmp (cmp_id),
    CONSTRAINT fk_drug FOREIGN KEY (drug_id) REFERENCES dim_drug (drug_id),
    CONSTRAINT fk_demo FOREIGN KEY (demo_id) REFERENCES dim_demo (demo_id),
    CONSTRAINT fk_type FOREIGN KEY (type_d) REFERENCES dim_type (type_d)
);

